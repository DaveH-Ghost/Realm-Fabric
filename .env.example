# =============================================================================
# Environment Variables for CampAIgn-RPG-Engine
# =============================================================================
#
# How .env files work:
# - They contain KEY=VALUE pairs that become environment variables.
# - Never commit real secrets to git (.env is in .gitignore).
# - Copy this file to .env and fill in your values.
#
# Multiple .env files (loaded in this order, later ones win):
#   .env           → base settings (commit .env.example instead)
#   .env.local     → your personal overrides (add this to .gitignore)
#
# Studio Settings (gear) can override these for the current process only.
#
# =============================================================================

# Provider: openrouter | featherless (default openrouter)
# LLM_PROVIDER=openrouter

# Max estimated input tokens before LLM calls are refused (default 32768)
# LLM_MAX_INPUT_TOKENS=32768

# Soft warning % of max for Studio Run-turn button (default 90; UI-only)
# LLM_INPUT_WARNING_PERCENT=90

# --- OpenRouter (LLM_PROVIDER=openrouter) ---
OPENROUTER_API_KEY=sk-or-...
# Model ids are provider-specific. DeepSeek V4 Flash on OpenRouter:
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# --- Featherless (LLM_PROVIDER=featherless) ---
# FEATHERLESS_API_KEY=...
# Same model, different id on Featherless (do not reuse the OpenRouter id):
# FEATHERLESS_MODEL=deepseek-ai/DeepSeek-V4-Flash
