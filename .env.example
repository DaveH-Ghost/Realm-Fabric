# =============================================================================
# Environment Variables for CampAIgn-RPG-Engine
# =============================================================================
#
# How .env files work:
# - They contain KEY=VALUE pairs that become environment variables.
# - Never commit real secrets to git (.env is in .gitignore).
# - Copy this file to .env and fill in your values.
#
# Multiple .env files (loaded in this order, later ones win):
#   .env           → base settings (commit .env.example instead)
#   .env.local     → your personal overrides (add this to .gitignore)
#
# You can also create:
#   .env.development
#   .env.production
# and load them explicitly in code if needed.
#
# =============================================================================

# --- Required for real LLM calls ---
OPENROUTER_API_KEY=sk-or-...

# --- Optional ---
# Override the model (default is deepseek/deepseek-v4-flash)
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash
# (v4-flash is currently one of the cheaper/faster DeepSeek options on OpenRouter)
